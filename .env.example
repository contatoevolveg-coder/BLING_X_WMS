# Supabase — use service_role key (never anon key) server-side
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Bling ERP v3 — App ID 338063
# Get Client ID and Secret from:
# https://www.bling.com.br/cadastro.aplicativos.php#/form/338063
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=https://syncstock.vercel.app/api/auth/callback

# Bling deposit ID for stock deductions (baixas)
# Find via GET /Api/v3/depositos after first OAuth login
BLING_DEPOSITO_ID=

# Token embedded in the Bling webhook registration URL:
# Register this URL in Bling: https://syncstock.vercel.app/api/webhooks/bling?token=YOUR_TOKEN
BLING_WEBHOOK_TOKEN=

# Smartgo WMS
WMS_API_KEY=
WMS_BASE_URL=https://apigateway.smartgo.com.br
WMS_DOC_DEPOSITANTE=

# Secret embedded in the WMS webhook URL path:
# Register this URL with Smartgo: https://syncstock.vercel.app/api/webhooks/wms/YOUR_TOKEN
WMS_WEBHOOK_TOKEN=

# Vercel automatically sets CRON_SECRET in deployed environments.
# Set it manually here only for local testing with `vercel dev`.
CRON_SECRET=
