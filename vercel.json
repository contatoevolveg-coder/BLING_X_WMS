{
  "crons": [
    {
      "path": "/api/crons/process-queue",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/crons/reconcile",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/crons/refresh-token",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 10
    }
  }
}
